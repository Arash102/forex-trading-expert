{
  "heartbeat_path": "data/live_runtime/heartbeat.json",
  "heartbeat_interval_seconds": 60,
  "watchdog_stale_after_seconds": 600,
  "restart_sleep_seconds": 30,
  "alerts": {
    "jsonl_path": "data/live_runtime/alerts.jsonl",
    "throttle_seconds": 1800,
    "telegram": {
      "enabled": false,
      "bot_token_env": "DEBCO_TELEGRAM_BOT_TOKEN",
      "chat_id_env": "DEBCO_TELEGRAM_CHAT_ID"
    }
  }
}
