  "validation": {
    "method": "walk_forward",
    "walk_forward": {
      "train_window_bars": 12000,
      "test_window_bars": 2000,
      "step_bars": 2000,
      "expanding": false,
      "min_train_bars": 5000,
      "purge_bars": 40
    },
    "cpcv": {
      "n_groups": 6,
      "n_test_groups": 2,
      "embargo_bars": 40,
      "purge": true,
      "max_splits": null
    }
  },
  "missing_values": {
    "strategy": "xgboost_native",
    "dropna": false
  },
  "candidate_filter": {
    "enabled": false,
    "set_name": "all_candles",
    "preset": "session_volatility_v1"
  },
  "model": {
    "type": "xgboost_classifier",
    "random_seed": 42,
    "threshold": 0.3,
    "objective_metric": "average_precision",
    "optuna_trials": 15,
    "inner_valid_fraction": 0.2,
    "min_inner_valid_bars": 500,
    "scale_pos_weight": "auto",
    "xgboost_base_params": {
      "objective": "binary:logistic",
      "eval_metric": "logloss",
      "tree_method": "hist",
      "n_jobs": -1,
      "missing": "nan"
    },
    "search_space": {
      "max_depth": [
        2,
        6
      ],
      "learning_rate": [
        0.01,
        0.15
      ],
      "n_estimators": [
        100,
        700
      ],
      "subsample": [
        0.55,
        1.0
      ],
      "colsample_bytree": [
        0.55,
        1.0
      ],
      "min_child_weight": [
        1,
        20
      ],
      "gamma": [
        0.0,
        5.0
      ],
      "reg_alpha": [
        0.0,
        10.0
      ],
      "reg_lambda": [
        0.1,
        30.0
      ]
    },
    "evaluation_probability_column": "y_prob_raw"
  },
  "calibration": {
    "enabled": true,
    "method": "sigmoid",
    "calibration_tail_fraction": 0.2,
    "min_calibration_bars": 800,
    "fallback_to_raw_if_single_class": true,
    "ece_bins": 10,
    "allow_inverted_sigmoid": false
  },
  "threshold_sweep": {
    "enabled": true,
    "probability_columns": [
      "y_prob_calibrated",
      "y_prob_raw"
    ],
    "thresholds": [
      0.2,
      0.25,
      0.3,
      0.35,
      0.4,
      0.45,
      0.5,
      0.55,
      0.6,
      0.65,
      0.7,
      0.75,
      0.8,
      0.85
    ]
  },
  "metrics": {
    "threshold_metrics": [
      "accuracy",
      "precision",
      "recall",
      "specificity",
      "f1",
      "balanced_accuracy",
      "mcc"
    ],
    "probability_metrics": [
      "roc_auc",
      "average_precision",
      "log_loss",
      "brier_score",
      "ece"
    ]
  },
  "sanity": {
