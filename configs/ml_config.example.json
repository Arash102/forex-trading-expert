{
  "input": {
    "ml_ready_dir": "data/ml_ready",
    "metadata_dir": "data/label_metadata",
    "ml_ready_file_template": "{symbol}_{profile}_ml_ready_{side}.csv",
    "metadata_file_template": "{symbol}_{profile}_metadata_{side}.csv"
  },
  "output": {
    "results_dir": "data/ml_results",
    "experiment_name": "xgb_v0_1_4_walk_forward"
  },
  "jobs": [
    {
      "enabled": true,
      "symbol": "EURUSD",
      "profile": "fast_15_8_h16",
      "side": "long"
    },
    {
      "enabled": false,
      "symbol": "EURUSD",
      "profile": "fast_15_8_h16",
      "side": "short"
    },
    {
      "enabled": false,
      "symbol": "EURUSD",
      "profile": "runner_20_10_h24",
      "side": "long"
    },
    {
      "enabled": false,
      "symbol": "EURUSD",
      "profile": "runner_20_10_h24",
      "side": "short"
    },
    {
      "enabled": false,
      "symbol": "XAUUSD",
      "profile": "active_1500_800_h32",
      "side": "long"
    },
    {
      "enabled": false,
      "symbol": "XAUUSD",
      "profile": "active_1500_800_h32",
      "side": "short"
    },
    {
      "enabled": false,
      "symbol": "XAUUSD",
      "profile": "runner_2200_1100_h40",
      "side": "long"
    },
    {
      "enabled": false,
      "symbol": "XAUUSD",
      "profile": "runner_2200_1100_h40",
      "side": "short"
    }
  ],
  "validation": {
    "method": "walk_forward",
    "walk_forward": {
      "train_window_bars": 12000,
      "test_window_bars": 2000,
      "step_bars": 2000,
      "expanding": false,
      "min_train_bars": 5000
    },
    "cpcv": {
      "n_groups": 6,
      "n_test_groups": 2,
      "embargo_bars": 24,
      "purge": true,
      "max_splits": null
    }
  },
  "missing_values": {
    "strategy": "xgboost_native",
    "dropna": false
  },
  "model": {
    "type": "xgboost_classifier",
    "random_seed": 42,
    "threshold": 0.6,
    "objective_metric": "average_precision",
    "optuna_trials": 25,
    "inner_valid_fraction": 0.2,
    "min_inner_valid_bars": 500,
    "scale_pos_weight": "auto",
    "xgboost_base_params": {
      "objective": "binary:logistic",
      "eval_metric": "logloss",
      "tree_method": "hist",
      "n_jobs": -1,
      "missing": "nan"
    },
    "search_space": {
      "max_depth": [2, 6],
      "learning_rate": [0.01, 0.15],
      "n_estimators": [100, 700],
      "subsample": [0.55, 1.0],
      "colsample_bytree": [0.55, 1.0],
      "min_child_weight": [1, 20],
      "gamma": [0.0, 5.0],
      "reg_alpha": [0.0, 10.0],
      "reg_lambda": [0.1, 30.0]
    }
  },
  "metrics": {
    "threshold_metrics": [
      "accuracy",
      "precision",
      "recall",
      "specificity",
      "f1",
      "balanced_accuracy",
      "mcc"
    ],
    "probability_metrics": [
      "roc_auc",
      "average_precision",
      "log_loss"
    ]
  },
  "sanity": {
    "expected_feature_count": 100,
    "target_column": "label",
    "forbidden_ml_columns": [
      "date",
      "symbol",
      "open",
      "high",
      "low",
      "close",
      "tick_volume",
      "spread",
      "real_volume",
      "dxy_close",
      "dxy_inverse_close",
      "index_close",
      "event_type",
      "outcome_label",
      "entry_price",
      "exit_price",
      "realized_pips",
      "mfe_pips",
      "mae_pips"
    ]
  }
}
